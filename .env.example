PROXY_TARGET_URL=PROXY_TARGET_URL
PROXY_API_KEY=PROXY_API_KEY
PROXY_PORT=3029
API_TIMEOUT=300
ACCESS_API_KEY=ACCESS_API_KEY
DEBUG_MODE=verbose

# verbose 模式下，写入 data/conversations 的流式事件是否完整保留（1=不截断，文件可能很大）
VERBOSE_FULL_STREAM=1

# 会话日志元数据索引（SQLite，不存完整 JSON）。Docker 请挂载整个 data 目录，见 doc/conversation-index-and-docker.md
# CONVERSATION_INDEX_PATH=conversation_index.sqlite3
# CONVERSATION_INDEX_DISABLED=1

# 模型定价 JSON 路径（默认可不传，使用项目根目录 model_pricing.json，见 doc/model-pricing.md）
# MODEL_PRICING_PATH=model_pricing.json